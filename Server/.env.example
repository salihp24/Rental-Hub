# Backend runtime settings (safe placeholders only).

# Port the Express API listens on.
PORT=5000

# Environment mode controls error output and cookie security behavior.
NODE_ENV=development

# MongoDB connection string used by Mongoose on startup.
# For production booking/payment transaction flows, use Atlas or replica set/sharded cluster URI.
MONGO_URI=<your_mongodb_connection_string>

# Secret used to sign JWT auth tokens.
JWT_SECRET=<your_jwt_secret>

# Token lifetime used for both JWT signing and auth cookies.
JWT_EXPIRES_IN=7d

# Frontend origin(s) allowed to call the API with credentials.
# Comma-separated values are supported, e.g.:
# CLIENT_URL=http://localhost:5173,https://your-frontend-url.com
CLIENT_URL=<your_frontend_origin_1>,<your_frontend_origin_2>

# Google OAuth credentials and callback URL.
GOOGLE_CLIENT_ID=<your_google_client_id>
GOOGLE_CLIENT_SECRET=<your_google_client_secret>
GOOGLE_CALLBACK_URL=<your_google_callback_url>

# SMTP settings used by nodemailer for forgot-password emails.
SMTP_HOST=<your_smtp_host>
SMTP_PORT=587
SMTP_USER=<your_smtp_user>
SMTP_PASS=<your_smtp_password>
EMAIL_FROM="Rental Hub <no-reply@example.com>"

# Razorpay credentials used for booking payments.
RAZORPAY_KEY_ID=<your_razorpay_key_id>
RAZORPAY_KEY_SECRET=<your_razorpay_key_secret>

# Cloudinary credentials used for product image uploads.
CLOUDINARY_CLOUD_NAME=<your_cloudinary_cloud_name>
CLOUDINARY_API_KEY=<your_cloudinary_api_key>
CLOUDINARY_API_SECRET=<your_cloudinary_api_secret>
