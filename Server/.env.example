# Backend runtime settings for local development.

# Port the Express API listens on.
PORT=5000

# Environment mode controls error output and cookie security behavior.
NODE_ENV=development

# MongoDB connection string used by Mongoose on startup.
MONGO_URI=mongodb://localhost:27017/rent_hub

# Secret used to sign JWT auth tokens.
JWT_SECRET=replace_with_a_secure_secret

# Token lifetime used for both JWT signing and auth cookies.
JWT_EXPIRES_IN=7d

# Frontend origin allowed to call the API with credentials.
CLIENT_URL=http://localhost:5173

# Razorpay credentials used for booking payments.
RAZORPAY_KEY_ID=rzp_test_SjgsNgdPqT1bmB
RAZORPAY_KEY_SECRET=EafdgGvSd502ciXCQokcWRv1

# Cloudinary credentials used for product image uploads.
CLOUDINARY_CLOUD_NAME=dyosml8nw
